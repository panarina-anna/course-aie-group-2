# ---------------------------------------------------------
# Общие правила игнорирования для репозитория студента
# ---------------------------------------------------------

# Системные файлы ОС
.DS_Store
Thumbs.db

# Конфигурации IDE/редакторов
.vscode/
.idea/
*.swp
*.swo

# Виртуальные окружения Python
.venv/
venv/
env/
ENV/
.conda/
.venv*/

# Кеши Python и скомпилированные файлы
__pycache__/
*.py[cod]
*$py.class

# Папки и файлы сборки/дистрибуции (если вдруг появятся)
build/
dist/
eggs/
*.egg-info/
.installed.cfg

# Кеши и артефакты тестов
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Журналы
*.log
logs/

# Кеши Jupyter Notebook
.ipynb_checkpoints

# Файлы окружения и конфигурации с потенциальными секретами
.env
*.env
.env.*
!.env.example

# Разное
*.tmp
*.bak
*.old
# ---------------------------------------------------------
# HW08-09: игнорирование больших файлов моделей
# ---------------------------------------------------------

# Игнорировать файлы моделей PyTorch (они могут быть огромными!)
homeworks/HW08-09/artifacts/best_model.pt
homeworks/HW08-09/artifacts/*.pt
homeworks/HW08-09/artifacts/*.pth

# Также игнорировать любые другие модели в других домашках
homeworks/**/artifacts/*.pt
homeworks/**/artifacts/*.pth
# ---------------------------------------------------------
# Игнорировать данные датасетов (они загружаются автоматически)
# ---------------------------------------------------------

# Игнорировать все данные EMNIST
homeworks/HW08-09/data/
homeworks/**/data/
**/data/
*.ubyte
*.zip
